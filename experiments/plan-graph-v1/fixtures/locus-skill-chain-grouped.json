{
  "version": 1,
  "id": "locus-skill-chain-grouped",
  "title": "Locus skill chain",
  "dense": true,
  "source": "src/examples.ts",
  "groups": [
    {"id": "entry", "label": "Entry", "members": ["user", "request"]},
    {"id": "reasoning", "label": "Reasoning", "members": ["route", "plan", "execute", "review"]},
    {"id": "durable", "label": "Durable surfaces", "members": ["tasks", "specs", "docs"]},
    {"id": "delivery", "label": "Delivery", "members": ["code", "pr"]}
  ],
  "nodes": [
    {"id": "user", "group": "entry", "title": "User"},
    {"id": "request", "group": "entry", "title": "Product request"},
    {"id": "route", "group": "reasoning", "title": "Route skill"},
    {"id": "plan", "group": "reasoning", "title": "Plan"},
    {"id": "execute", "group": "reasoning", "title": "Execute"},
    {"id": "review", "group": "reasoning", "title": "Review"},
    {"id": "tasks", "group": "durable", "title": "Tasks"},
    {"id": "specs", "group": "durable", "title": "Specs"},
    {"id": "docs", "group": "durable", "title": "Docs"},
    {"id": "code", "group": "delivery", "title": "Code"},
    {"id": "pr", "group": "delivery", "title": "Pull request"}
  ],
  "edges": [
    {"id": "user-request", "from": "user", "to": "request", "kind": "primary"},
    {"id": "request-route", "from": "request", "to": "route", "kind": "primary"},
    {"id": "route-plan", "from": "route", "to": "plan", "kind": "primary"},
    {"id": "plan-execute", "from": "plan", "to": "execute", "kind": "primary"},
    {"id": "execute-review", "from": "execute", "to": "review", "kind": "primary"},
    {"id": "review-plan", "from": "review", "to": "plan", "kind": "feedback"},
    {"id": "plan-tasks", "from": "plan", "to": "tasks", "kind": "support"},
    {"id": "plan-specs", "from": "plan", "to": "specs", "kind": "support"},
    {"id": "review-docs", "from": "review", "to": "docs", "kind": "support"},
    {"id": "execute-code", "from": "execute", "to": "code", "kind": "primary"},
    {"id": "review-pr", "from": "review", "to": "pr", "kind": "primary"},
    {"id": "tasks-execute", "from": "tasks", "to": "execute", "kind": "support"},
    {"id": "specs-review", "from": "specs", "to": "review", "kind": "support"}
  ],
  "constraints": [
    {"kind": "before", "from": "entry", "to": "reasoning", "reason": "request precedes reasoning"},
    {"kind": "before", "from": "reasoning", "to": "delivery", "reason": "review precedes delivery"}
  ]
}
