{
  "version": 1,
  "id": "semantic-redraw-control",
  "title": "Semantic redraw control",
  "dense": false,
  "source": "tests/semantic-redraw-spec.test.ts",
  "groups": [
    {"id": "input", "label": "Input", "members": ["request", "context"]},
    {"id": "compile", "label": "Compile", "members": ["planner", "renderer"]},
    {"id": "output", "label": "Output", "members": ["scene", "png"]}
  ],
  "nodes": [
    {"id": "request", "group": "input", "title": "Request"},
    {"id": "context", "group": "input", "title": "Repository context"},
    {"id": "planner", "group": "compile", "title": "Semantic planner"},
    {"id": "renderer", "group": "compile", "title": "Scene renderer"},
    {"id": "scene", "group": "output", "title": "Editable scene"},
    {"id": "png", "group": "output", "title": "Rendered PNG"}
  ],
  "edges": [
    {"id": "request-planner", "from": "request", "to": "planner", "kind": "primary"},
    {"id": "context-planner", "from": "context", "to": "planner", "kind": "support"},
    {"id": "planner-renderer", "from": "planner", "to": "renderer", "kind": "primary"},
    {"id": "renderer-scene", "from": "renderer", "to": "scene", "kind": "primary"},
    {"id": "scene-png", "from": "scene", "to": "png", "kind": "primary"}
  ],
  "constraints": [
    {"kind": "before", "from": "input", "to": "compile", "reason": "input precedes compilation"},
    {"kind": "before", "from": "compile", "to": "output", "reason": "compilation precedes output"}
  ]
}
