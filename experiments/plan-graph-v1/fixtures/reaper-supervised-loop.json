{
  "version": 1,
  "id": "reaper-supervised-loop",
  "title": "Supervised trading execution loop",
  "dense": false,
  "source": "examples/reaper_graphspec.ts",
  "groups": [
    {"id": "decision", "label": "Decision", "members": ["signal", "strategy", "risk"]},
    {"id": "execution", "label": "Execution", "members": ["executor", "order", "reaper"]}
  ],
  "nodes": [
    {"id": "signal", "group": "decision", "title": "Signal"},
    {"id": "strategy", "group": "decision", "title": "Strategy"},
    {"id": "risk", "group": "decision", "title": "Risk gate"},
    {"id": "executor", "group": "execution", "title": "Executor"},
    {"id": "order", "group": "execution", "title": "Order"},
    {"id": "reaper", "group": "execution", "title": "Reaper"}
  ],
  "edges": [
    {"id": "signal-strategy", "from": "signal", "to": "strategy", "kind": "primary"},
    {"id": "strategy-risk", "from": "strategy", "to": "risk", "kind": "primary"},
    {"id": "risk-executor", "from": "risk", "to": "executor", "kind": "primary"},
    {"id": "executor-order", "from": "executor", "to": "order", "kind": "primary"},
    {"id": "order-reaper", "from": "order", "to": "reaper", "kind": "primary"},
    {"id": "reaper-risk", "from": "reaper", "to": "risk", "kind": "feedback"}
  ],
  "constraints": [
    {"kind": "before", "from": "decision", "to": "execution", "reason": "approval precedes execution"}
  ]
}
