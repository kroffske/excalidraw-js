{
  "template": "sequence.interaction",
  "title": "Report request",
  "palette": "high-contrast",
  "participants": [
    { "id": "analyst", "name": "Analyst", "status": "added" },
    { "id": "portal", "name": "Customer portal", "status": "changed" },
    { "id": "api", "name": "Insights API", "status": "risk" },
    { "id": "store", "name": "Analytics store" }
  ],
  "messages": [
    {
      "id": "request",
      "from": "analyst",
      "to": "portal",
      "label": "request cohort report",
      "status": "added"
    },
    {
      "id": "query",
      "from": "portal",
      "to": "api",
      "label": "fetch cohort data",
      "status": "changed"
    },
    {
      "id": "queued",
      "from": "api",
      "to": "analyst",
      "label": "confirm report is queued",
      "kind": "return",
      "status": "risk"
    },
    {
      "id": "read",
      "from": "api",
      "to": "store",
      "label": "read approved aggregates",
      "status": "removed"
    },
    {
      "id": "cache-check",
      "from": "api",
      "to": "store",
      "label": "check cached aggregate"
    },
    {
      "id": "result",
      "from": "store",
      "to": "api",
      "label": "return aggregate rows",
      "kind": "return"
    },
    {
      "id": "report",
      "from": "api",
      "to": "portal",
      "label": "return rendered report",
      "kind": "return"
    },
    {
      "id": "complete",
      "from": "portal",
      "to": "analyst",
      "label": "show completed report",
      "kind": "return"
    }
  ],
  "notes": [
    {
      "id": "access-rule",
      "message": "query",
      "text": "Access rules are applied before aggregation."
    }
  ]
}
